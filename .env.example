# === EMERALD ZERO-TRUST VAULT — EXAMPLE CONFIG ===
# Copy to .env and fill in your values.
# NEVER commit .env to version control.

# Master encryption key (256-bit hex, 64 hex chars)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
EMERALD_MASTER_SECURE_KEY=

# Sentinel auth token (any random string, shared between services)
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
SENTINEL_AUTH_TOKEN=

# Sentinel URL — change if not using Docker Compose
SENTINEL_URL=http://emerald-vault-sentinel:8443

# === OBFUSCATED CREDENTIALS ===
# Fill these in after running: python obfuscate_environment.py
EMERALD_GHP_01=
EMERALD_HF_02=
EMERALD_TGB_03=
EMERALD_TUI_04=
EMERALD_OLA_05=http://localhost:11434

# GitHub metadata
EMERALD_OWN_06=your-github-username
EMERALD_REP_07=emerald-engine

# Hugging Face metadata
EMERALD_HFU_08=your-hf-username
EMERALD_HFS_09=emerald-engine

EMERALD_GIT_REMOTE=origin
HACKER_BOT_INTERVAL=3600
